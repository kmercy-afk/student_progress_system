<!DOCTYPE html>
<html>
  <head>
    <title>Student Progress Tracking System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", media: "all", "data-turbolinks-track": "reload" %>
    <%= javascript_pack_tag "application", "data-turbolinks-track": "reload" %>
  </head>

  <body>
    <header class="site-header">
      <div class="header-title">
        <%= link_to "Student Progress Tracking System", root_path %>
      </div>

      <nav class="site-nav">
        <%= link_to "Home", root_path %>

        <% if logged_in? %>
          <%= link_to "Dashboard", dashboard_path %>
          <%= link_to "Students", students_path %>
          <%= link_to "Courses", courses_path %>
          <%= link_to "Assignments", assignments_path %>
          <%= link_to "Progress", progresses_path %>
          <%= link_to "My Account", profile_path %>

          <% if admin? %>
            <%= link_to "Admin Dashboard", admin_dashboard_path %>
          <% end %>

          <%= button_to "Logout", logout_path, method: :delete, class: "nav-button" %>
        <% else %>
          <%= link_to "Login", login_path %>
          <%= link_to "Create Account", signup_path %>
        <% end %>
      </nav>
    </header>

    <main class="main-content">
      <% flash.each do |key, message| %>
        <div class="flash <%= key %>"><%= message %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <p>&copy; 2026 Student Progress Tracking System. All rights reserved.</p>
    </footer>
  </body>
</html>