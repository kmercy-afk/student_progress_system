<%= form_with(model: progress) do |form| %>
  <% if progress.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(progress.errors.count, "error") %> prohibited this progress from being saved:</h2>

      <ul>
        <% progress.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :student_id, "Student" %>
    <%= form.collection_select :student_id,
                               current_user.students,
                               :id,
                               :name,
                               prompt: "Select Student" %>
  </div>

  <div class="field">
    <%= form.label :course_id, "Course" %>
    <%= form.collection_select :course_id,
                               current_user.courses,
                               :id,
                               :title,
                               prompt: "Select Course" %>
  </div>

  <div class="field">
    <%= form.label :completion_percentage, "Completion Percentage" %>
    <%= form.number_field :completion_percentage,
                          min: 0,
                          max: 100,
                          placeholder: "Enter progress from 0 to 100" %>
  </div>

  <div class="field">
    <%= form.label :status, "Status" %>
    <%= form.select :status,
                    ["Not Started", "In Progress", "Completed"],
                    prompt: "Select Status" %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>