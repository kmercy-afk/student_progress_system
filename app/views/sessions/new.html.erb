<h1>Login</h1>
<p>Login to access the Student Progress Tracking System.</p>

<%= form_with url: login_path, local: true do |form| %>
  <div>
    <%= form.label :email, "Email" %><br>
    <%= form.email_field :email, placeholder: "Enter your email address" %>
  </div>

  <div>
    <%= form.label :password, "Password" %><br>
    <%= form.password_field :password, placeholder: "Enter your password" %>
  </div>

  <div>
    <%= form.submit "Login" %>
  </div>
<% end %>

<hr>

<%= button_to "Guest Login", guest_login_path, method: :post %>
<%= button_to "Admin Guest Login", admin_guest_login_path, method: :post %>

<p><%= link_to "Back to Top Page", root_path %></p>